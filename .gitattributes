# =============================================================================
# qbtLiveApp — .gitattributes
# 모든 텍스트 파일의 줄바꿈을 LF 로 통일
# =============================================================================

# 텍스트 파일은 LF 로 체크아웃 (Windows 에서도 LF 로 저장)
* text=auto eol=lf

# 명시적으로 텍스트 (확장자별)
*.js     text eol=lf
*.jsx    text eol=lf
*.ts     text eol=lf
*.tsx    text eol=lf
*.json   text eol=lf
*.md     text eol=lf
*.yml    text eol=lf
*.yaml   text eol=lf
*.html   text eol=lf
*.css    text eol=lf
*.xml    text eol=lf
*.gradle text eol=lf
*.sh     text eol=lf
*.properties text eol=lf

# Windows 전용 파일은 CRLF 유지
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# 바이너리 — 절대 변환하지 말 것
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.ttf binary
*.otf binary
*.woff binary
*.woff2 binary
*.mp3 binary
*.mp4 binary
*.webm binary
*.pdf binary
*.zip binary
*.jar binary
*.apk binary
*.aab binary
*.keystore binary
*.jks binary
